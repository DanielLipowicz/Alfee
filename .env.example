PORT=3000
NODE_ENV=development
SESSION_SECRET=zmien-na-mocny-sekret
GOOGLE_CLIENT_ID=twoj-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=twoj-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# HTTPS / reverse proxy:
# - ustaw TRUST_PROXY=1 gdy aplikacja jest za nginx/caddy/cloudflare
# - SESSION_COOKIE_SECURE=auto to najbezpieczniejszy domyslny tryb dla HTTP+HTTPS
# - FORCE_HTTPS=true wlacz dopiero po poprawnym skonfigurowaniu TLS na proxy
TRUST_PROXY=
SESSION_COOKIE_SECURE=auto
FORCE_HTTPS=false

# Opcjonalnie: lista maili administratorow rozdzielona przecinkami
ADMIN_EMAILS=admin@firma.pl

# Opcjonalnie: lista maili kierownikow rozdzielona przecinkami
MANAGER_EMAILS=manager@firma.pl

# Opcjonalnie: nazwa organizacji tworzona podczas migracji ze starej bazy
DEFAULT_ORGANIZATION_NAME=Domyslna organizacja

# Opcjonalnie: wlasna sciezka bazy danych
# DB_PATH=data/app.db

# PDF HACCP (zalecane dla poprawnych polskich znakow):
# ustaw pelna sciezke do fontu Unicode (np. Noto Sans / DejaVu Sans)
# Linux/Docker: HACCP_PDF_FONT_PATH=/app/assets/fonts/NotoSans-Regular.ttf
# Windows: HACCP_PDF_FONT_PATH=C:\sciezka\do\Alfee\assets\fonts\NotoSans-Regular.ttf
HACCP_PDF_FONT_PATH=

# Logowanie aplikacji:
# LOG_LEVEL: debug | info | warn | error
# LOG_MAX_SIZE_BYTES: limit rozmiaru pojedynczego pliku logow (domyslnie 5MB)
# LOG_DIR: katalog na logi (domyslnie data/logs)
# LOG_MIRROR_STDOUT: true/false - czy logi maja byc tez wysylane na stdout/stderr
LOG_LEVEL=info
LOG_MAX_SIZE_BYTES=5242880
# LOG_DIR=data/logs
LOG_MIRROR_STDOUT=true
