PORT=3000
NODE_ENV=development
SESSION_SECRET=zmien-na-mocny-sekret
GOOGLE_CLIENT_ID=twoj-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=twoj-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# HTTPS / reverse proxy:
# - ustaw TRUST_PROXY=1 gdy aplikacja jest za nginx/caddy/cloudflare
# - SESSION_COOKIE_SECURE=auto to najbezpieczniejszy domyslny tryb dla HTTP+HTTPS
# - FORCE_HTTPS=true wlacz dopiero po poprawnym skonfigurowaniu TLS na proxy
TRUST_PROXY=
SESSION_COOKIE_SECURE=auto
FORCE_HTTPS=false

# Opcjonalnie: lista maili administratorow rozdzielona przecinkami
ADMIN_EMAILS=admin@firma.pl

# Opcjonalnie: lista maili kierownikow rozdzielona przecinkami
MANAGER_EMAILS=manager@firma.pl

# Opcjonalnie: nazwa organizacji tworzona podczas migracji ze starej bazy
DEFAULT_ORGANIZATION_NAME=Domyslna organizacja

# Opcjonalnie: wlasna sciezka bazy danych
# DB_PATH=data/app.db
