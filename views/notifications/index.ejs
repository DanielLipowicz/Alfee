<%- include("../partials/top", { title }) %>

<section class="card">
  <div class="section-head">
    <h1>Powiadomienia</h1>
    <% if (notifications.length > 0) { %>
    <form method="POST" action="/notifications/read-all">
      <button class="btn" type="submit">Oznacz wszystko jako przeczytane</button>
    </form>
    <% } %>
  </div>

  <% if (notifications.length === 0) { %>
  <p>Brak powiadomien.</p>
  <% } else { %>
  <div class="notification-list">
    <% notifications.forEach((notification) => { %>
    <article class="notification-item <%= notification.is_read === 1 ? 'notification-item--read' : '' %>">
      <div class="notification-head">
        <strong><%= t(notification.title) %></strong>
        <% if (notification.is_read !== 1) { %>
        <span class="badge badge--progress">Nowe</span>
        <% } else { %>
        <span class="muted">Przeczytane</span>
        <% } %>
      </div>
      <p><%= t(notification.message) %></p>
      <p class="muted"><%= notification.created_at %></p>
      <div class="actions">
        <% if (notification.url) { %>
        <a class="btn btn--primary" href="<%= notification.url %>">Otworz</a>
        <% } %>
        <% if (notification.is_read !== 1) { %>
        <form method="POST" action="/notifications/<%= notification.id %>/read">
          <input type="hidden" name="redirectTo" value="/notifications" />
          <button class="btn" type="submit">Oznacz jako przeczytane</button>
        </form>
        <% } %>
      </div>
    </article>
    <% }) %>
  </div>
  <% } %>
</section>

<%- include("../partials/bottom") %>
