<%- include("../partials/top", { title }) %>

<% if (generatedObserverCredentials) { %>
<section class="card narrow">
  <h2>Dane startowe obserwatora</h2>
  <p>
    Konto:
    <strong><%= generatedObserverCredentials.email %></strong>
  </p>
  <label for="generated-observer-password">Haslo startowe (pokazane tylko raz)</label>
  <div class="credential-copy-row">
    <input
      id="generated-observer-password"
      type="text"
      readonly
      value="<%= generatedObserverCredentials.password %>"
      class="credential-copy-input"
    />
    <button class="btn btn--primary" type="button" id="copy-generated-observer-password">
      Kopiuj
    </button>
  </div>
  <p class="muted" id="copy-generated-observer-password-feedback" aria-live="polite"></p>
</section>
<script>
  (() => {
    const input = document.getElementById("generated-observer-password");
    const button = document.getElementById("copy-generated-observer-password");
    const feedback = document.getElementById("copy-generated-observer-password-feedback");
    if (!input || !button) {
      return;
    }

    button.addEventListener("click", async () => {
      try {
        input.focus();
        input.select();
        input.setSelectionRange(0, input.value.length);
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(input.value);
        } else {
          document.execCommand("copy");
        }
        if (feedback) {
          feedback.textContent = "Haslo skopiowane do schowka.";
        }
      } catch (_error) {
        if (feedback) {
          feedback.textContent = "Nie udalo sie skopiowac automatycznie. Skopiuj haslo recznie.";
        }
      }
    });
  })();
</script>
<% } %>

<section class="grid admin-grid">
  <article class="card">
    <div class="section-head">
      <h1>Nowe konto pracownika</h1>
      <a class="btn" href="/manager/dashboard">Powrot do panelu</a>
    </div>

    <p class="muted">
      Konto zostanie utworzone jako lokalne i od razu przypisane do aktywnej organizacji.
    </p>

    <form class="form-stack" method="POST" action="/manager/employees">
      <label>
        Email
        <input
          type="email"
          name="email"
          value="<%= formData?.email || '' %>"
          required
          autocomplete="email"
        />
      </label>

      <label>
        Imie i nazwisko
        <input
          type="text"
          name="name"
          value="<%= formData?.name || '' %>"
          required
          maxlength="120"
          autocomplete="name"
        />
      </label>

      <label>
        Haslo
        <input type="password" name="password" required autocomplete="new-password" />
      </label>

      <label>
        Powtorz haslo
        <input
          type="password"
          name="passwordConfirm"
          required
          autocomplete="new-password"
        />
      </label>

      <p class="muted">
        Haslo musi miec min. 10 znakow, mala i wielka litere, cyfre oraz znak specjalny.
      </p>

      <button class="btn btn--primary" type="submit">Utworz konto pracownika</button>
    </form>
  </article>

  <article class="card">
    <h2>Nowe konto obserwatora</h2>

    <p class="muted">
      Podaj tylko adres email. System wygeneruje haslo startowe, ktore kierownik moze przekazac nowemu obserwatorowi.
    </p>

    <form class="form-stack" method="POST" action="/manager/observers">
      <label>
        Email obserwatora
        <input
          type="email"
          name="email"
          value="<%= observerFormData?.email || '' %>"
          required
          autocomplete="email"
        />
      </label>

      <button class="btn btn--primary" type="submit">Utworz konto obserwatora</button>
    </form>
  </article>
</section>

<%- include("../partials/bottom") %>
