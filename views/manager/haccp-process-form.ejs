<%- include("../partials/top", { title }) %>
<%
  const fieldTypeLabels = {
    BOOLEAN: `BOOLEAN (${t("Yes/No")})`,
    NUMBER: `NUMBER (${t("Number")})`,
    TEXT: `TEXT (${t("Text")})`,
    SELECT: `SELECT (${t("Select list")})`,
  };
%>

<section class="card">
  <div class="heading-with-tooltip">
    <h1><%= formMode === "create" ? "Nowy proces HACCP" : "Edycja procesu HACCP" %></h1>
    <span class="inline-tooltip">
      <button type="button" class="tooltip-trigger" aria-label="<%= t('What is HACCP?') %>">?</button>
      <span class="tooltip-bubble" role="tooltip">
        <%= t('HACCP means "Hazard Analysis and Critical Control Points".') %>
      </span>
    </span>
  </div>

  <% if (errors && errors.length > 0) { %>
  <div class="flash flash--error">
    <% errors.forEach((error) => { %>
    <div><%= error %></div>
    <% }) %>
  </div>
  <% } %>

  <form
    method="POST"
    action="<%= formMode === 'create' ? '/manager/haccp/processes' : `/manager/haccp/processes/${processId}?_method=PUT` %>"
    class="form-stack"
  >
    <label>
      Nazwa procesu
      <input type="text" name="name" required value="<%= formData.name %>" />
    </label>

    <label>
      Opis
      <input type="text" name="description" value="<%= formData.description %>" />
    </label>

    <div class="grid haccp-grid-3">
      <label>
        Czestotliwosc
        <select name="frequencyType" id="frequencyTypeSelect">
          <% frequencyOptions.forEach((option) => { %>
          <option
            value="<%= option.value %>"
            <%= formData.frequencyType === option.value ? "selected" : "" %>
          >
            <%= option.label %>
          </option>
          <% }) %>
        </select>
      </label>

      <label>
        Parametr czestotliwosci
        <input
          type="number"
          min="1"
          name="frequencyValue"
          id="frequencyValueInput"
          value="<%= formData.frequencyValue %>"
        />
        <span id="frequencyValueHelp" class="muted"></span>
      </label>

      <div class="form-stack">
        <label class="checkbox-row">
          <input type="hidden" name="isActive" value="0" />
          <input type="checkbox" name="isActive" value="1" <%= formData.isActive ? "checked" : "" %> />
          Proces aktywny
        </label>
        <label class="checkbox-row">
          <input type="hidden" name="isCcp" value="0" />
          <input type="checkbox" name="isCcp" value="1" <%= formData.isCcp ? "checked" : "" %> />
          Oznacz jako CCP
          <span class="inline-tooltip">
            <button type="button" class="tooltip-trigger" aria-label="<%= t('What is CCP?') %>">?</button>
            <span class="tooltip-bubble" role="tooltip">
              <%= t('Marks this process as CCP, e.g. "Thermal processing of meat".') %>
            </span>
          </span>
        </label>
      </div>
    </div>

    <section class="tenant-card">
      <div class="section-head">
        <h2>Definicja pol</h2>
        <button class="btn" type="button" id="add-field">Dodaj pole</button>
      </div>

      <div id="fields-list" class="form-stack">
        <% formData.fields.forEach((field, index) => { %>
        <div class="haccp-field-row">
          <label>
            Nazwa
            <input type="text" name="fieldName" required value="<%= field.name %>" />
          </label>
          <label>
            Typ
            <select name="fieldType">
              <% fieldTypes.forEach((type) => { %>
              <option value="<%= type %>" <%= field.type === type ? "selected" : "" %>>
                <%= fieldTypeLabels[type] || type %>
              </option>
              <% }) %>
            </select>
          </label>
          <label>
            Wymagane
            <select name="fieldRequired">
              <option value="1" <%= field.required ? "selected" : "" %>>TAK</option>
              <option value="0" <%= !field.required ? "selected" : "" %>>NIE</option>
            </select>
          </label>
          <label>
            Min (NUMBER)
            <input type="text" name="fieldMinValue" value="<%= field.minValue %>" />
          </label>
          <label>
            Max (NUMBER)
            <input type="text" name="fieldMaxValue" value="<%= field.maxValue %>" />
          </label>
          <label>
            Allowed (SELECT)
            <input
              type="text"
              name="fieldAllowedValues"
              value="<%= Array.isArray(field.allowedValues) ? field.allowedValues.join(', ') : '' %>"
              placeholder="np. TAK, NIE, N/A"
            />
          </label>
          <label>
            Kolejnosc
            <input type="number" min="1" name="fieldOrder" value="<%= field.order || (index + 1) %>" />
          </label>
          <button class="btn btn--danger remove-field" type="button">Usun</button>
        </div>
        <% }) %>
      </div>
    </section>

    <div class="actions">
      <button class="btn btn--primary" type="submit">
        <%= formMode === "create" ? "Utworz proces" : "Zapisz zmiany" %>
      </button>
      <a class="btn" href="/manager/haccp/processes">Anuluj</a>
    </div>
  </form>
</section>

<script>
  const fieldsList = document.getElementById("fields-list");
  const addFieldButton = document.getElementById("add-field");
  const frequencyTypeSelect = document.getElementById("frequencyTypeSelect");
  const frequencyValueInput = document.getElementById("frequencyValueInput");
  const frequencyValueHelp = document.getElementById("frequencyValueHelp");
  const localizedFieldTypeLabels = {
    BOOLEAN: <%- JSON.stringify(fieldTypeLabels.BOOLEAN) %>,
    NUMBER: <%- JSON.stringify(fieldTypeLabels.NUMBER) %>,
    TEXT: <%- JSON.stringify(fieldTypeLabels.TEXT) %>,
    SELECT: <%- JSON.stringify(fieldTypeLabels.SELECT) %>,
  };

  function updateFrequencyValueUI() {
    const type = frequencyTypeSelect.value;
    const config = {
      ON_DEMAND: {
        enabled: false,
        placeholder: "Brak",
        help: "Wpis wykonywany ad-hoc, bez stalego harmonogramu.",
      },
      PER_BATCH: {
        enabled: false,
        placeholder: "Brak",
        help: "Wpis wykonywany dla kazdej partii.",
      },
      SHIFT_START: {
        enabled: true,
        placeholder: "Domyslnie 1",
        help: "Opcjonalnie: liczba wpisow na poczatku zmiany.",
      },
      SHIFT_END: {
        enabled: true,
        placeholder: "Domyslnie 1",
        help: "Opcjonalnie: liczba wpisow na koncu zmiany.",
      },
      DAILY: {
        enabled: true,
        placeholder: "Domyslnie 1",
        help: "Opcjonalnie: liczba wpisow dziennie.",
      },
      TWICE_DAILY: {
        enabled: false,
        placeholder: "Stale 2",
        help: "Stala wartosc 2 wpisy dziennie.",
      },
      EVERY_X_HOURS: {
        enabled: true,
        placeholder: "np. 4",
        help: "Wymagane: co ile godzin ma byc wykonany wpis.",
      },
      WEEKLY: {
        enabled: false,
        placeholder: "Brak",
        help: "Wpis wykonywany raz na tydzien.",
      },
      MONTHLY: {
        enabled: false,
        placeholder: "Brak",
        help: "Wpis wykonywany raz na miesiac.",
      },
      FIXED_TIMES_DAILY: {
        enabled: true,
        placeholder: "np. 3",
        help: "Wymagane: ile stalych godzin dziennie wymaga wpisu.",
      },
    };

    const current = config[type] || config.ON_DEMAND;
    frequencyValueInput.disabled = !current.enabled;
    frequencyValueInput.placeholder = current.placeholder;
    frequencyValueHelp.textContent = current.help;

    if (!current.enabled) {
      if (type === "TWICE_DAILY") {
        frequencyValueInput.value = "2";
      } else {
        frequencyValueInput.value = "";
      }
    }
  }

  function bindRemoveFieldButtons() {
    document.querySelectorAll(".remove-field").forEach((button) => {
      button.onclick = () => {
        const rows = fieldsList.querySelectorAll(".haccp-field-row");
        if (rows.length <= 1) {
          return;
        }
        button.closest(".haccp-field-row").remove();
      };
    });
  }

  addFieldButton.onclick = () => {
    const nextOrder = fieldsList.querySelectorAll(".haccp-field-row").length + 1;
    const row = document.createElement("div");
    row.className = "haccp-field-row";
    row.innerHTML = `
      <label>
        Nazwa
        <input type="text" name="fieldName" required />
      </label>
      <label>
        Typ
        <select name="fieldType">
          <option value="BOOLEAN">${localizedFieldTypeLabels.BOOLEAN}</option>
          <option value="NUMBER" selected>${localizedFieldTypeLabels.NUMBER}</option>
          <option value="TEXT">${localizedFieldTypeLabels.TEXT}</option>
          <option value="SELECT">${localizedFieldTypeLabels.SELECT}</option>
        </select>
      </label>
      <label>
        Wymagane
        <select name="fieldRequired">
          <option value="1" selected>TAK</option>
          <option value="0">NIE</option>
        </select>
      </label>
      <label>
        Min (NUMBER)
        <input type="text" name="fieldMinValue" />
      </label>
      <label>
        Max (NUMBER)
        <input type="text" name="fieldMaxValue" />
      </label>
      <label>
        Allowed (SELECT)
        <input type="text" name="fieldAllowedValues" />
      </label>
      <label>
        Kolejnosc
        <input type="number" min="1" name="fieldOrder" value="${nextOrder}" />
      </label>
      <button class="btn btn--danger remove-field" type="button">Usun</button>
    `;
    fieldsList.appendChild(row);
    bindRemoveFieldButtons();
  };

  frequencyTypeSelect.addEventListener("change", updateFrequencyValueUI);
  updateFrequencyValueUI();
  bindRemoveFieldButtons();
</script>

<%- include("../partials/bottom") %>
