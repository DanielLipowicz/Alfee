<%- include("../partials/top", { title }) %>

<section class="card narrow">
  <div class="section-head">
    <h1>Uzupelnij brakujacy wpis HACCP</h1>
    <a class="btn" href="/manager/haccp/alerts">Powrot do alertow</a>
  </div>

  <div class="tenant-card">
    <p><strong>Alert:</strong> <%= alert.message %></p>
    <p><strong>Proces:</strong> <%= process.name %></p>
  </div>

  <% if (errors && errors.length > 0) { %>
  <div class="flash flash--error">
    <% errors.forEach((error) => { %>
    <div><%= error %></div>
    <% }) %>
  </div>
  <% } %>

  <form method="POST" action="/manager/haccp/alerts/<%= alert.id %>/fill-missing" class="form-stack">
    <label>
      Data i godzina, dla ktorej wpis ma zastosowanie
      <input
        type="datetime-local"
        name="recordedForAt"
        required
        value="<%= recordedForAt || '' %>"
      />
    </label>

    <% process.fields.forEach((field) => { %>
    <% const inputName = `field_${field.id}`; %>
    <% const previousValue = previousValues[inputName] == null ? "" : previousValues[inputName]; %>

    <label>
      <%= field.name %>
      <% if (Number(field.required) === 1) { %>
      <span class="muted">(wymagane)</span>
      <% } %>

      <% if (field.type === "TEXT") { %>
      <input
        type="text"
        name="<%= inputName %>"
        value="<%= previousValue %>"
        <%= Number(field.required) === 1 ? "required" : "" %>
      />
      <% } else if (field.type === "NUMBER") { %>
      <input
        type="text"
        name="<%= inputName %>"
        value="<%= previousValue %>"
        <%= Number(field.required) === 1 ? "required" : "" %>
      />
      <span class="muted">
        Zakres:
        <%= field.min_value == null ? "-inf" : field.min_value %>
        do
        <%= field.max_value == null ? "+inf" : field.max_value %>
      </span>
      <% } else if (field.type === "BOOLEAN") { %>
      <select name="<%= inputName %>" <%= Number(field.required) === 1 ? "required" : "" %>>
        <option value="" <%= previousValue === "" ? "selected" : "" %>>Wybierz</option>
        <option value="1" <%= String(previousValue) === "1" ? "selected" : "" %>>TAK</option>
        <option value="0" <%= String(previousValue) === "0" ? "selected" : "" %>>NIE</option>
      </select>
      <% } else if (field.type === "SELECT") { %>
      <select name="<%= inputName %>" <%= Number(field.required) === 1 ? "required" : "" %>>
        <option value="">Wybierz</option>
        <% field.allowed_values.forEach((option) => { %>
        <option value="<%= option %>" <%= String(previousValue) === String(option) ? "selected" : "" %>>
          <%= option %>
        </option>
        <% }) %>
      </select>
      <% } %>
    </label>
    <% }) %>

    <label>
      Dzialanie korygujace (wymagane dla ALERT/CRITICAL)
      <textarea name="correctiveAction" rows="4"><%= correctiveAction || "" %></textarea>
    </label>

    <div class="actions">
      <button class="btn btn--primary" type="submit">Zapisz brakujacy wpis</button>
      <a class="btn" href="/manager/haccp/alerts">Anuluj</a>
    </div>
  </form>
</section>

<%- include("../partials/bottom") %>
