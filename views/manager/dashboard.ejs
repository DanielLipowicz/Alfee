<%- include("../partials/top", { title }) %>

<section class="grid stats">
  <article class="card">
    <h2><%= t("Tasks") %></h2>
    <strong><%= stats.tasks %></strong>
  </article>
  <article class="card">
    <h2><%= t("Employees") %></h2>
    <strong><%= stats.employees %></strong>
  </article>
  <article class="card">
    <h2><%= t("Assignments") %></h2>
    <strong><%= stats.assignments %></strong>
  </article>
  <article class="card">
    <h2><%= t("In progress") %></h2>
    <strong><%= stats.active %></strong>
  </article>
</section>

<section class="card">
  <div class="section-head">
    <h2><%= t("Latest assignments") %></h2>
    <a class="btn" href="/manager/assignments"><%= t("Full overview") %></a>
  </div>

  <% if (recentAssignments.length === 0) { %>
  <p><%= t("No assigned tasks.") %></p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th><%= t("Task") %></th>
        <th><%= t("Employee") %></th>
        <th><%= t("Progress") %></th>
        <th><%= t("Status") %></th>
      </tr>
    </thead>
    <tbody>
      <% recentAssignments.forEach((item) => { %>
      <tr>
        <td><a href="/manager/assignments/<%= item.id %>"><%= item.title %></a></td>
        <td><%= item.employee_name %></td>
        <td><%= item.completed_steps %>/<%= item.total_steps %> (<%= item.percentage %>%)</td>
        <td>
          <span class="badge <%= item.status === 'completed' ? 'badge--done' : 'badge--progress' %>">
            <%= item.status === "completed" ? t("Completed") : t("In progress") %>
          </span>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include("../partials/bottom") %>
