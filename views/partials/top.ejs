<!doctype html>
<html lang="<%= locale || 'pl' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title ? `${t(title)} | Alfee` : "Alfee" %></title>
    <link rel="stylesheet" href="/css/styles.css?v=<%= assetVersion %>" />
  </head>
  <body>
    <header class="header">
      <div class="container header__content">
        <a class="brand" href="/">Alfee</a>
        <div class="header__right">
          <form class="locale-switch" method="GET" action="">
            <label for="locale-select"><%= t("Jezyk") %></label>
            <select
              id="locale-select"
              name="lang"
              onchange="window.location.href=this.options[this.selectedIndex].value"
            >
              <% (localeOptions || []).forEach((item) => { %>
              <option
                value="<%= withLocale(item.code) %>"
                <%= item.code === locale ? "selected" : "" %>
              >
                <%= item.label %>
              </option>
              <% }) %>
            </select>
          </form>
          <nav class="nav">
            <% if (currentUser && currentUser.role === "admin") { %>
            <% if (isAdminManagerMode) { %>
            <a href="/manager/dashboard">Panel kierownika</a>
            <a href="/manager/tasks">Zadania</a>
            <a href="/manager/haccp">HACCP</a>
            <a href="/manager/employees/new">Nowy pracownik/obserwator</a>
            <a href="/manager/assignments">Postep</a>
            <% } %>
            <a href="/admin/organizations">Organizacje</a>
            <a href="/profile">Profil</a>
            <a href="/notifications">
              Powiadomienia
              <% if (unreadNotifications > 0) { %>
              <span class="nav-badge"><%= unreadNotifications %></span>
              <% } %>
            </a>
            <a href="/logout">Wyloguj</a>
            <% } else if (currentUser && currentUser.role === "manager") { %>
            <a href="/manager/dashboard">Panel</a>
            <a href="/manager/tasks">Zadania</a>
            <a href="/manager/haccp">HACCP</a>
            <a href="/manager/employees/new">Nowy pracownik/obserwator</a>
            <a href="/manager/assignments">Postep</a>
            <a href="/profile">Profil</a>
            <a href="/notifications">
              Powiadomienia
              <% if (unreadNotifications > 0) { %>
              <span class="nav-badge"><%= unreadNotifications %></span>
              <% } %>
            </a>
            <a href="/logout">Wyloguj</a>
            <% } else if (currentUser && currentUser.role === "employee") { %>
            <a href="/employee/tasks">Moje zadania</a>
            <a href="/employee/haccp">HACCP</a>
            <a href="/profile">Profil</a>
            <a href="/notifications">
              Powiadomienia
              <% if (unreadNotifications > 0) { %>
              <span class="nav-badge"><%= unreadNotifications %></span>
              <% } %>
            </a>
            <a href="/logout">Wyloguj</a>
            <% } else if (currentUser && currentUser.role === "observer") { %>
            <a href="/observer/tasks">Obserwowane zadania</a>
            <a href="/profile">Profil</a>
            <a href="/notifications">
              Powiadomienia
              <% if (unreadNotifications > 0) { %>
              <span class="nav-badge"><%= unreadNotifications %></span>
              <% } %>
            </a>
            <a href="/logout">Wyloguj</a>
            <% } else { %>
          <a href="/login">Logowanie</a>
          <a href="/register">Rejestracja</a>
          <% } %>
        </nav>

          <% if (currentUser) { %>
          <% const roleLabel = currentUser.role === "admin" ? t("administrator") : currentUser.role === "manager" ? t("kierownik") : currentUser.role === "observer" ? t("obserwator") : t("pracownik"); %>
          <div class="session-user">
            <span class="session-user__label">Zalogowano:</span>
            <strong><%= currentUser.name || currentUser.email %></strong>
            <span class="session-user__email">(<%= currentUser.email %>)</span>
            <span class="session-user__sep">|</span>
            <span>Typ konta: <strong><%= roleLabel %></strong></span>
          </div>
          <% } %>

          <% if (currentUser && currentUser.role === "admin" && isAdminManagerMode) { %>
          <div class="admin-mode-bar">
            <span>
              Tryb kierownika:
              <strong><%= activeOrganization?.name || "nieznana organizacja" %></strong>
            </span>
            <form method="POST" action="/admin/manager-mode/exit">
              <button class="btn" type="submit">Wyjdz z trybu</button>
            </form>
          </div>
          <% } %>

          <% if (currentUser && currentUser.role === "manager") { %>
          <form class="tenant-switch" method="POST" action="/manager/organization/switch">
            <label for="organizationId">Organizacja</label>
            <select
              id="organizationId"
              name="organizationId"
              onchange="this.form.submit()"
              <%= userOrganizations && userOrganizations.length > 0 ? '' : 'disabled' %>
            >
              <% if (!userOrganizations || userOrganizations.length === 0) { %>
              <option value="">Brak organizacji</option>
              <% } else { %>
              <% userOrganizations.forEach((organization) => { %>
              <option
                value="<%= organization.id %>"
                <%= activeOrganization && Number(activeOrganization.id) === Number(organization.id) ? 'selected' : '' %>
              >
                <%= organization.name %>
              </option>
              <% }) %>
              <% } %>
            </select>
          </form>
          <% } %>
        </div>
      </div>
    </header>
    <main class="container content">
      <% if (flash) { %>
      <div class="flash flash--<%= flash.type %>"><%= t(flash.text) %></div>
      <% } %>
