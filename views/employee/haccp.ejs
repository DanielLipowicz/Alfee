<%- include("../partials/top", { title }) %>

<section class="card">
  <div class="section-head">
    <h1>HACCP - moje procesy</h1>
  </div>

  <% if (processes.length === 0) { %>
  <p>Brak aktywnych procesow HACCP przypisanych do Twoich organizacji.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Proces</th>
        <th>Organizacja</th>
        <th>Czestotliwosc</th>
        <th>CCP</th>
        <th>Akcja</th>
      </tr>
    </thead>
    <tbody>
      <% processes.forEach((process) => { %>
      <tr>
        <td>
          <strong><%= process.name %></strong>
          <% if (process.description) { %>
          <div class="muted"><%= process.description %></div>
          <% } %>
        </td>
        <td><%= process.organization_name %></td>
        <td>
          <%= process.frequency_type %>
          <% if (process.frequency_value != null) { %>
          (<%= process.frequency_value %>)
          <% } %>
        </td>
        <td>
          <span class="badge <%= Number(process.is_ccp) === 1 ? 'badge--critical' : 'badge--ok' %>">
            <%= Number(process.is_ccp) === 1 ? "TAK" : "NIE" %>
          </span>
        </td>
        <td>
          <a class="btn btn--primary" href="/employee/haccp/processes/<%= process.id %>/new-entry">
            Dodaj wpis
          </a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<section class="card">
  <h2>Alerty powiazane z moimi wpisami</h2>
  <% if (alerts.length === 0) { %>
  <p>Brak alertow.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Priorytet</th>
        <th>Proces</th>
        <th>Wpis</th>
        <th>Tresc</th>
        <th>Data</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% alerts.forEach((alert) => { %>
      <tr>
        <td>
          <span class="badge badge--severity-<%= String(alert.severity || '').toLowerCase() %>">
            <%= alert.severity %>
          </span>
        </td>
        <td><%= alert.process_name %></td>
        <td><a href="/employee/haccp/entries/<%= alert.entry_id %>">#<%= alert.entry_id %></a></td>
        <td><%= alert.message %></td>
        <td><%= alert.created_at %></td>
        <td><%= Number(alert.resolved) === 1 ? `Rozwiazany (${alert.resolved_at || "-"})` : "Otwarty" %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<section class="card">
  <h2>Moje wpisy</h2>
  <% if (entries.length === 0) { %>
  <p>Nie dodano jeszcze wpisow HACCP.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Proces</th>
        <th>Organizacja</th>
        <th>Status</th>
        <th>Review</th>
        <th>Data</th>
        <th>Akcja</th>
      </tr>
    </thead>
    <tbody>
      <% entries.forEach((entry) => { %>
      <tr>
        <td><%= entry.id %></td>
        <td><%= entry.process_name %></td>
        <td><%= entry.organization_name %></td>
        <td>
          <span class="badge badge--<%= String(entry.status || '').toLowerCase() %>">
            <%= entry.status %>
          </span>
        </td>
        <td>
          <%= Number(entry.is_reviewed) === 1 ? `TAK (${entry.reviewed_at || "-"})` : "NIE" %>
        </td>
        <td><%= entry.recorded_for_at || entry.created_at %></td>
        <td>
          <a class="btn" href="/employee/haccp/entries/<%= entry.id %>">Szczegoly</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include("../partials/bottom") %>
