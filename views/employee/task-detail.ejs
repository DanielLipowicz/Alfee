<%- include("../partials/top", { title }) %>

<section class="card">
  <h1><%= assignment.title %></h1>
  <p>
    Organizacja:
    <strong><%= assignment.organization_name %></strong>
  </p>
  <p>
    Status:
    <span class="badge <%= assignment.status === 'completed' ? 'badge--done' : 'badge--progress' %>">
      <%= assignment.status === "completed" ? "Ukonczone" : "W toku" %>
    </span>
  </p>
  <p>Postep: <strong><%= progress.completed_steps %>/<%= progress.total_steps %> (<%= progress.percentage %>%)</strong></p>
</section>

<section class="card">
  <h2>Czynnosci do wykonania</h2>
  <ol class="steps">
    <% steps.forEach((step) => { %>
    <li class="step-item">
      <div class="step-head">
        <strong><%= step.step_text %></strong>
        <span class="badge <%= step.completed === 1 ? 'badge--done' : 'badge--progress' %>">
          <%= step.completed === 1 ? "Ukonczona" : "Niewykonana" %>
        </span>
      </div>

      <div class="actions">
        <form method="POST" action="/employee/tasks/<%= assignment.id %>/steps/<%= step.id %>/toggle">
          <button class="btn" type="submit">
            <%= step.completed === 1 ? "Cofnij ukonczenie" : "Oznacz jako ukonczona" %>
          </button>
        </form>
      </div>

      <form
        class="form-inline"
        method="POST"
        action="/employee/tasks/<%= assignment.id %>/steps/<%= step.id %>/evidence"
        enctype="multipart/form-data"
      >
        <input
          type="file"
          name="evidenceImage"
          accept="image/*"
          capture="environment"
          required
        />
        <button class="btn btn--primary" type="submit">Dodaj zdjecie</button>
      </form>
      <p class="muted">Na telefonie mozesz zrobic zdjecie bezposrednio aparatem.</p>

      <% const evidence = evidenceByStep[step.id] || []; %>
      <% if (evidence.length === 0) { %>
      <p class="muted">Brak zdjec.</p>
      <% } else { %>
      <div class="evidence-grid">
        <% evidence.forEach((item) => { %>
        <figure>
          <img src="<%= item.image_path %>" alt="Zdjecie dowodowe" />
          <figcaption><%= item.uploaded_at %></figcaption>
        </figure>
        <% }) %>
      </div>
      <% } %>
    </li>
    <% }) %>
  </ol>
</section>

<%- include("../partials/bottom") %>
