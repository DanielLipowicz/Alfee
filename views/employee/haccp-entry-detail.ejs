<%- include("../partials/top", { title }) %>

<section class="card">
  <div class="section-head">
    <h1>Wpis HACCP #<%= details.entry.id %></h1>
    <a class="btn" href="/employee/haccp">Powrot</a>
  </div>

  <div class="grid haccp-grid-2">
    <article class="tenant-card">
      <h2>Metryka</h2>
      <p><strong>Proces:</strong> <%= details.entry.process_name %></p>
      <p><strong>Status:</strong> <span class="badge badge--<%= String(details.entry.status || '').toLowerCase() %>"><%= details.entry.status %></span></p>
      <p><strong>Utworzono:</strong> <%= details.entry.created_at %></p>
      <p><strong>Dotyczy czasu:</strong> <%= details.entry.recorded_for_at || details.entry.created_at %></p>
      <p>
        <strong>Zatwierdzony:</strong>
        <%= Number(details.entry.is_reviewed) === 1 ? `TAK (${details.entry.reviewed_at || "-"})` : "NIE" %>
      </p>
    </article>

    <article class="tenant-card">
      <h2>Informacja</h2>
      <p class="muted">
        Jesli wpis ma status ALERT/CRITICAL, wymagane jest dzialanie korygujace i moze pojawic sie alert.
      </p>
    </article>
  </div>
</section>

<section class="card">
  <h2>Wartosci formularza</h2>
  <% if (details.values.length === 0) { %>
  <p>Brak wartosci.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Pole</th>
        <th>Typ</th>
        <th>Wartosc</th>
      </tr>
    </thead>
    <tbody>
      <% details.values.forEach((value) => { %>
      <tr>
        <td><%= value.field_name %></td>
        <td><%= value.field_type %></td>
        <td><%= value.value == null ? "-" : value.value %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<section class="card">
  <h2>Dzialania korygujace</h2>
  <% if (details.correctiveActions.length === 0) { %>
  <p>Brak dzialan korygujacych.</p>
  <% } else { %>
  <ul class="haccp-list">
    <% details.correctiveActions.forEach((action) => { %>
    <li>
      <strong><%= action.created_at %>:</strong>
      <%= action.description %>
    </li>
    <% }) %>
  </ul>
  <% } %>
</section>

<section class="card">
  <h2>Alerty powiazane</h2>
  <% if (details.alerts.length === 0) { %>
  <p>Brak alertow.</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <th>Priorytet</th>
        <th>Tresc</th>
        <th>Data</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% details.alerts.forEach((alert) => { %>
      <tr>
        <td>
          <span class="badge badge--severity-<%= String(alert.severity || '').toLowerCase() %>">
            <%= alert.severity %>
          </span>
        </td>
        <td><%= t(alert.message) %></td>
        <td><%= alert.created_at %></td>
        <td><%= Number(alert.resolved) === 1 ? `Rozwiazany (${alert.resolved_at || "-"})` : "Otwarty" %></td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</section>

<%- include("../partials/bottom") %>
