{
  "name": "alfee-gatling-ts",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "target/bundle",
  "dependencies": {
    "@gatling.io/core": "3.14.905",
    "@gatling.io/http": "3.14.905"
  },
  "devDependencies": {
    "@gatling.io/cli": "3.14.905",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  },
  "scripts": {
    "clean": "rimraf target",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && gatling build --typescript",
    "run": "tsc --noEmit && gatling run --typescript --simulation roleCapacitySimulation",
    "recorder": "gatling recorder --typescript"
  }
}

